<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <payment>
            <amwal_pay>
                <active>0</active>
                <title>Amwal Pay</title>
                <environment>uat</environment>
                <payment_view>1</payment_view>
                <contact_info_type>1</contact_info_type>
                <has_items>0</has_items>
                <has_apple_pay>0</has_apple_pay>
                <checkout_color>#7f22ff</checkout_color>
                <ignore_receipt>0</ignore_receipt>
                <allowspecific>0</allowspecific>
                <debug>1</debug>
                <model>Amwal\Pay\Model\AmwalPay</model>
                <is_gateway>1</is_gateway>
                <can_use_checkout>1</can_use_checkout>
                <can_capture>1</can_capture>
                <can_capture_partial>1</can_capture_partial>
                <can_authorize>1</can_authorize>
                <can_refund>1</can_refund>
                <can_void>1</can_void>
                <can_refund_invoice_partial>1</can_refund_invoice_partial>
                <can_cancel>1</can_cancel>
            </amwal_pay>
        </payment>
        <csp>
            <mode>
                <storefront>
                    <report_only>0</report_only>
                </storefront>
                <admin>
                    <report_only>0</report_only>
                </admin>
            </mode>
        </csp>
    </default>
</config>